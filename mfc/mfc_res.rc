            MENUITEM "$ED0100 : SRAM(гГїпљљгГїпљљгГїпљљ[гГїпљљUгГїпљљпЊМиМ®пљњпљљ)", IDM_AREA_SRUSER
            MENUITEM "$F00000 : CG ROM",            IDM_AREA_CGROM
            MENUITEM "$FC0000 : SCSI ROM",          IDM_AREA_SCSIROM
            MENUITEM "$FE0000 : IPL ROM",           IDM_AREA_IPLROM
        END
        POPUP "гГїпљљAгГїпљљhгГїпљљгГїпљљгГїпљљXгГїпљљqгГїпљљXгГїпљљgгГїпљљгГїпљљ(&H)"
