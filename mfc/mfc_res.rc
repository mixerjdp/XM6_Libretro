IDR_US_MEMORYMENU MENU
BEGIN
    POPUP "POPUP"
    BEGIN
        MENUITEM "Enter &Address...",           IDM_MEMORY_ADDR
        MENUITEM "&New Window...",              IDM_MEMORY_NEWWIN
        MENUITEM SEPARATOR
        MENUITEM "&Byte Size",                  IDM_MEMORY_BYTE
        MENUITEM "&Word Size",                  IDM_MEMORY_WORD
        MENUITEM "&Long Size",                  IDM_MEMORY_LONG
        MENUITEM SEPARATOR
        MENUITEM "$000000-$0FFFFF",             IDM_MEMORY_0
        MENUITEM "$100000-$1FFFFF",             IDM_MEMORY_1
        MENUITEM "$200000-$2FFFFF",             IDM_MEMORY_2
        MENUITEM "$300000-$3FFFFF",             IDM_MEMORY_3
        MENUITEM "$400000-$4FFFFF",             IDM_MEMORY_4
        MENUITEM "$500000-$5FFFFF",             IDM_MEMORY_5
        MENUITEM "$600000-$6FFFFF",             IDM_MEMORY_6
        MENUITEM "$700000-$7FFFFF",             IDM_MEMORY_7
        MENUITEM "$800000-$8FFFFF",             IDM_MEMORY_8
        MENUITEM "$900000-$9FFFFF",             IDM_MEMORY_9
        MENUITEM "$A00000-$AFFFFF",             IDM_MEMORY_A
        MENUITEM "$B00000-$BFFFFF",             IDM_MEMORY_B
        MENUITEM "$C00000-$CFFFFF",             IDM_MEMORY_C
        MENUITEM "$D00000-$DFFFFF",             IDM_MEMORY_D
        MENUITEM "$E00000-$EFFFFF",             IDM_MEMORY_E
        MENUITEM "$F00000-$FFFFFF",             IDM_MEMORY_F
        MENUITEM SEPARATOR
        POPUP "&Register"
        BEGIN
            MENUITEM "D0 ($00000000)",              IDM_REG_D0
            MENUITEM "D1 ($00000000)",              IDM_REG_D1
            MENUITEM "D2 ($00000000)",              IDM_REG_D2
            MENUITEM "D3 ($00000000)",              IDM_REG_D3
            MENUITEM "D4 ($00000000)",              IDM_REG_D4
            MENUITEM "D5 ($00000000)",              IDM_REG_D5
            MENUITEM "D6 ($00000000)",              IDM_REG_D6
            MENUITEM "D7 ($00000000)",              IDM_REG_D7
            MENUITEM SEPARATOR
            MENUITEM "A0 ($00000000)",              IDM_REG_A0
            MENUITEM "A1 ($00000000)",              IDM_REG_A1
            MENUITEM "A2 ($00000000)",              IDM_REG_A2
            MENUITEM "A3 ($00000000)",              IDM_REG_A3
            MENUITEM "A4 ($00000000)",              IDM_REG_A4
            MENUITEM "A5 ($00000000)",              IDM_REG_A5
            MENUITEM "A6 ($00000000)",              IDM_REG_A6
            MENUITEM "A7 ($00000000)",              IDM_REG_A7
            MENUITEM SEPARATOR
            MENUITEM "USP ($00000000)",             IDM_REG_USP
            MENUITEM "SSP ($00000000)",             IDM_REG_SSP
            MENUITEM "PC ($000000)",                IDM_REG_PC
        END
        POPUP "&Stack"
        BEGIN
            MENUITEM "(A7+00) : $000000",           IDM_STACK_0
            MENUITEM "(A7+02) : $000000",           IDM_STACK_1
            MENUITEM "(A7+04) : $000000",           IDM_STACK_2
