            MENUITEM "$000400 : IOCSгГїпљљxгГїпљљNгГїпљљ^",  IDM_AREA_IOCS
            MENUITEM "$001800 : DOSгГїпљљxгГїпљљNгГїпљљ^",   IDM_AREA_DOS
            MENUITEM "$006800 : Human68k",          IDM_AREA_HUMAN
            MENUITEM SEPARATOR
            MENUITEM "$C00000 : гГїпљљOгГїпљљгГїпљљгГїпљљtгГїпљљBгГїпљљbгГїпљљNVRAM", IDM_AREA_GVRAM
            MENUITEM "$E00000 : гГїпљљeгГїпљљLгГїпљљXгГїпљљgVRAM", IDM_AREA_TVRAM
            MENUITEM "$E80000 : CRTгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_CRTC
            MENUITEM "$E82000 : гГїпљљrгГїпљљfгГїпљљIгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_VC
            MENUITEM "$E84000 : DMAгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_DMAC
            MENUITEM "$E86000 : гГїпљљGгГїпљљгГїпљљгГїпљљAгГїпљљZгГїпљљbгГїпљљg", IDM_AREA_AREA
            MENUITEM "$E88000 : гГїпљљ}гГїпљљгГїпљљгГїпљљ`гГїпљљtгГїпљљ@гГїпљљгГїпљљгГїпљљNгГїпљљVгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљyгГїпљљгГїпљљгГїпљљtгГїпљљFгГїпљљгГїпљљгГїпљљгГїпљљ", IDM_AREA_MFP
            MENUITEM "$E8A000 : гГїпљљгГїпљљгГїпљљAгГїпљљгГїпљљгГїпљљ^гГїпљљCгГїпљљгГїпљљгГїпљљNгГїпљљгГїпљљгГїпљљbгГїпљљN", IDM_AREA_RTC
            MENUITEM "$E8C000 : гГїпљљvгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљ^", IDM_AREA_PRN
            MENUITEM "$E8E000 : гГїпљљVгГїпљљXгГїпљљeгГїпљљгГїпљљгГїпљљ|гГїпљљ[гГїпљљg", IDM_AREA_SYSP
            MENUITEM "$E90000 : FMгГїпљљгГїпљљгГїпљљгГїпљљ",    IDM_AREA_OPM
            MENUITEM "$E92000 : ADPCM",             IDM_AREA_APCM
            MENUITEM "$E94000 : гГїпљљtгГїпљљгГїпљљгГїпљљbгГїпљљsгГїпљљ[гГїпљљfгГїпљљBгГїпљљXгГїпљљNгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_FDC
            MENUITEM "$E96000 : SASIгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_SASI
            MENUITEM "$E98000 : гГїпљљVгГїпљљгГїпљљгГїпљљAгГїпљљгГїпљљгГїпљљRгГїпљљ~гГїпљљгГїпљљгГїпљљjгГїпљљPгГїпљљ[гГїпљљVгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_SCC
            MENUITEM "$E9A000 : гГїпљљpгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљ|гГїпљљ[гГїпљљg", IDM_AREA_PPI
            MENUITEM "$E9C000 : I/OгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_IOSC
            MENUITEM "$E9F000 : Windrv",            IDM_AREA_WDRV
            MENUITEM "$EA0000 : SCSIгГїпљљvгГїпљљгГїпљљгГїпљљgгГїпљљRгГїпљљгГїпљљгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_SCSI
            MENUITEM "$EAFA00 : MIDIгГїпљљRгГїпљљгГїпљљгГїпљљgгГїпљљгГїпљљгГїпљљ[гГїпљљгГїпљљ", IDM_AREA_MIDI
            MENUITEM "$EB0000 : гГїпљљXгГїпљљvгГїпљљгГїпљљгГїпљљCгГїпљљgгГїпљљгГїпљљгГїпљљWгГїпљљXгГїпљљ^", IDM_AREA_SPREG
            MENUITEM "$EB8000 : гГїпљљXгГїпљљvгГїпљљгГїпљљгГїпљљCгГїпљљgгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљ", IDM_AREA_SPMEM
            MENUITEM "$ECC000 : Mercury-Unit",      IDM_AREA_MERC
            MENUITEM "$ECE000 : Neptune-X",         IDM_AREA_NEPX
