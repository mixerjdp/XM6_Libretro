IDR_DISMENU MENU
BEGIN
    POPUP "POPUP"
    BEGIN
        MENUITEM "・ｽA・ｽh・ｽ・ｽ・ｽX・ｽ・ｽ・ｽw・ｽ・ｽ(&A)...", IDM_DIS_ADDR
        MENUITEM "・ｽV・ｽ・ｽ・ｽ・ｽ・ｽE・ｽB・ｽ・ｽ・ｽh・ｽE(&N)...", IDM_DIS_NEWWIN
        MENUITEM SEPARATOR
        MENUITEM "PC・ｽﾖ移難ｿｽ(&P)",            IDM_DIS_PC
        MENUITEM "PC・ｽﾉ難ｿｽ・ｽ・ｽ(&Y)",        IDM_DIS_SYNC
        MENUITEM SEPARATOR
        POPUP "MPU・ｽ・ｽ・ｽW・ｽX・ｽ^(&R)"
        BEGIN
            MENUITEM "D0 ($00000000)",              IDM_REG_D0
            MENUITEM "D1 ($00000000)",              IDM_REG_D1
            MENUITEM "D2 ($00000000)",              IDM_REG_D2
            MENUITEM "D3 ($00000000)",              IDM_REG_D3
            MENUITEM "D4 ($00000000)",              IDM_REG_D4
            MENUITEM "D5 ($00000000)",              IDM_REG_D5
            MENUITEM "D6 ($00000000)",              IDM_REG_D6
            MENUITEM "D7 ($00000000)",              IDM_REG_D7
            MENUITEM SEPARATOR
            MENUITEM "A0 ($00000000)",              IDM_REG_A0
            MENUITEM "A1 ($00000000)",              IDM_REG_A1
            MENUITEM "A2 ($00000000)",              IDM_REG_A2
            MENUITEM "A3 ($00000000)",              IDM_REG_A3
            MENUITEM "A4 ($00000000)",              IDM_REG_A4
            MENUITEM "A5 ($00000000)",              IDM_REG_A5
            MENUITEM "A6 ($00000000)",              IDM_REG_A6
            MENUITEM "A7 ($00000000)",              IDM_REG_A7
            MENUITEM SEPARATOR
            MENUITEM "USP ($00000000)",             IDM_REG_USP
            MENUITEM "SSP ($00000000)",             IDM_REG_SSP
            MENUITEM "PC ($000000)",                IDM_REG_PC
        END
        POPUP "・ｽX・ｽ^・ｽb・ｽN(&S)"
        BEGIN
            MENUITEM "(A7+00) : $000000",           IDM_STACK_0
            MENUITEM "(A7+02) : $000000",           IDM_STACK_1
            MENUITEM "(A7+04) : $000000",           IDM_STACK_2
            MENUITEM "(A7+06) : $000000",           IDM_STACK_3
            MENUITEM "(A7+08) : $000000",           IDM_STACK_4
            MENUITEM "(A7+0A) : $000000",           IDM_STACK_5
            MENUITEM "(A7+0C) : $000000",           IDM_STACK_6
            MENUITEM "(A7+0E) : $000000",           IDM_STACK_7
            MENUITEM "(A7+10) : $000000",           IDM_STACK_8
            MENUITEM "(A7+12) : $000000",           IDM_STACK_9
            MENUITEM "(A7+14) : $000000",           IDM_STACK_A
            MENUITEM "(A7+16) : $000000",           IDM_STACK_B
            MENUITEM "(A7+18) : $000000",           IDM_STACK_C
            MENUITEM "(A7+1A) : $000000",           IDM_STACK_D
            MENUITEM "(A7+1C) : $000000",           IDM_STACK_E
            MENUITEM "(A7+1E) : $000000",           IDM_STACK_F
        END
        POPUP "・ｽu・ｽ・ｽ・ｽ[・ｽN・ｽ|・ｽC・ｽ・ｽ・ｽg(&B)"
        BEGIN
            MENUITEM "0 : $000000",                 IDM_DIS_BREAKP0
            MENUITEM "1 : $000000",                 IDM_DIS_BREAKP1
            MENUITEM "2 : $000000",                 IDM_DIS_BREAKP2
            MENUITEM "3 : $000000",                 IDM_DIS_BREAKP3
            MENUITEM "4 : $000000",                 IDM_DIS_BREAKP4
            MENUITEM "5 : $000000",                 IDM_DIS_BREAKP5
            MENUITEM "6 : $000000",                 IDM_DIS_BREAKP6
            MENUITEM "7 : $000000",                 IDM_DIS_BREAKP7
        END
        POPUP "・ｽ・ｽ・ｽ闕橸ｿｽﾝベ・ｽN・ｽ^(&V)"
        BEGIN
            MENUITEM "・ｽ・ｽ・ｽZ・ｽb・ｽg",          IDM_DIS_RESET
            MENUITEM "・ｽo・ｽX・ｽG・ｽ・ｽ・ｽ[",      IDM_DIS_BUSERR
