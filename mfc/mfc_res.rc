IDR_MEMORYMENU MENU
BEGIN
    POPUP "POPUP"
    BEGIN
        MENUITEM "гГїпљљAгГїпљљhгГїпљљгГїпљљгГїпљљXгГїпљљгГїпљљгГїпљљwгГїпљљгГїпљљ(&A)...", IDM_MEMORY_ADDR
        MENUITEM "гГїпљљVгГїпљљгГїпљљгГїпљљгГїпљљгГїпљљEгГїпљљBгГїпљљгГїпљљгГїпљљhгГїпљљE(&N)...", IDM_MEMORY_NEWWIN
        MENUITEM SEPARATOR
