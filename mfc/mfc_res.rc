    BEGIN
        MENUITEM "Enter &Address...",           IDM_MEMORY_ADDR
        MENUITEM "&New Window...",              IDM_MEMORY_NEWWIN
        MENUITEM SEPARATOR
        MENUITEM "&Byte Size",                  IDM_MEMORY_BYTE
        MENUITEM "&Word Size",                  IDM_MEMORY_WORD
        MENUITEM "&Long Size",                  IDM_MEMORY_LONG
