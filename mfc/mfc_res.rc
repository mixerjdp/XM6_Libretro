            MENUITEM "$E82000 : Video Controller",  IDM_AREA_VC
            MENUITEM "$E84000 : DMA Controller",    IDM_AREA_DMAC
            MENUITEM "$E86000 : Area Set",          IDM_AREA_AREA
            MENUITEM "$E88000 : Multi-Function Peripheral", IDM_AREA_MFP
            MENUITEM "$E8A000 : Real-Time Clock",   IDM_AREA_RTC
            MENUITEM "$E8C000 : Printer",           IDM_AREA_PRN
            MENUITEM "$E8E000 : System Port",       IDM_AREA_SYSP
            MENUITEM "$E90000 : FM Sound",          IDM_AREA_OPM
            MENUITEM "$E92000 : ADPCM",             IDM_AREA_APCM
            MENUITEM "$E94000 : Floppy Disk Controller", IDM_AREA_FDC
            MENUITEM "$E96000 : SASI Controller",   IDM_AREA_SASI
            MENUITEM "$E98000 : Serial Communication", IDM_AREA_SCC
            MENUITEM "$E9A000 : Parallel Port",     IDM_AREA_PPI
            MENUITEM "$E9C000 : I/O Contoller",     IDM_AREA_IOSC
            MENUITEM "$E9F000 : Windrv",            IDM_AREA_WDRV
            MENUITEM "$EA0000 : SCSI Protocol Controller", IDM_AREA_SCSI
            MENUITEM "$EAFA00 : MIDI Controller",   IDM_AREA_MIDI
            MENUITEM "$EB0000 : Sprite Register",   IDM_AREA_SPREG
            MENUITEM "$EB8000 : Sprite Memory",     IDM_AREA_SPMEM
            MENUITEM "$ECC000 : Mercury-Unit",      IDM_AREA_MERC
            MENUITEM "$ECE000 : Neptune-X",         IDM_AREA_NEPX
            MENUITEM SEPARATOR
            MENUITEM "$ED0000 : SRAM Memory Switch", IDM_AREA_SRSW
            MENUITEM "$ED0100 : SRAM User Area",    IDM_AREA_SRUSER
            MENUITEM "$F00000 : CG ROM",            IDM_AREA_CGROM
            MENUITEM "$FC0000 : SCSI ROM",          IDM_AREA_SCSIROM
            MENUITEM "$FE0000 : IPL ROM",           IDM_AREA_IPLROM
        END
        POPUP "Address &History"
        BEGIN
            MENUITEM "$000000",                     IDM_HISTORY_0
            MENUITEM "$000000",                     IDM_HISTORY_1
            MENUITEM "$000000",                     IDM_HISTORY_2
            MENUITEM "$000000",                     IDM_HISTORY_3
            MENUITEM "$000000",                     IDM_HISTORY_4
            MENUITEM "$000000",                     IDM_HISTORY_5
            MENUITEM "$000000",                     IDM_HISTORY_6
            MENUITEM "$000000",                     IDM_HISTORY_7
            MENUITEM "$000000",                     IDM_HISTORY_8
            MENUITEM "$000000",                     IDM_HISTORY_9
        END
    END
END

IDR_US_BREAKPMENU MENU
BEGIN
    POPUP "POPUP"
    BEGIN
        MENUITEM "&Enable",                     IDM_BREAKP_ENABLE
        MENUITEM "&Clear Counter",              IDM_BREAKP_CLEAR
        MENUITEM "&Delete",                     IDM_BREAKP_DEL
        MENUITEM SEPARATOR
        MENUITEM "Enter &Address...",           IDM_BREAKP_ADDR
        POPUP "Address &History"
        BEGIN
            MENUITEM "$000000",                     IDM_HISTORY_0
            MENUITEM "$000000",                     IDM_HISTORY_1
            MENUITEM "$000000",                     IDM_HISTORY_2
            MENUITEM "$000000",                     IDM_HISTORY_3
            MENUITEM "$000000",                     IDM_HISTORY_4
            MENUITEM "$000000",                     IDM_HISTORY_5
            MENUITEM "$000000",                     IDM_HISTORY_6
            MENUITEM "$000000",                     IDM_HISTORY_7
            MENUITEM "$000000",                     IDM_HISTORY_8
            MENUITEM "$000000",                     IDM_HISTORY_9
        END
        MENUITEM SEPARATOR
        MENUITEM "E&rase All",                  IDM_BREAKP_ALL
    END
END


