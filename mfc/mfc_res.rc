            MENUITEM "trap #2 (PCM8)",              IDM_DIS_TRAP2
            MENUITEM "trap #3 (ZMUSIC)",            IDM_DIS_TRAP3
            MENUITEM "trap #4 (MX/MA/ML/MC/MNDRV)", IDM_DIS_TRAP4
            MENUITEM "trap #5 (CDC)",               IDM_DIS_TRAP5
            MENUITEM "trap #6",                     IDM_DIS_TRAP6
            MENUITEM "trap #7",                     IDM_DIS_TRAP7
