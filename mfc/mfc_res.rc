            MENUITEM "A7 ($00000000)",              IDM_REG_A7
            MENUITEM SEPARATOR
            MENUITEM "USP ($00000000)",             IDM_REG_USP
            MENUITEM "SSP ($00000000)",             IDM_REG_SSP
            MENUITEM "PC ($000000)",                IDM_REG_PC
        END
        POPUP "&Stack"
        BEGIN
            MENUITEM "(A7+00) : $000000",           IDM_STACK_0
