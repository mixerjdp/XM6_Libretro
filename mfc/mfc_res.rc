            MENUITEM "6 : $000000",                 IDM_DIS_BREAKP6
            MENUITEM "7 : $000000",                 IDM_DIS_BREAKP7
        END
        POPUP "&Vector"
        BEGIN
            MENUITEM "Reset",                       IDM_DIS_RESET
            MENUITEM "Bus Error",                   IDM_DIS_BUSERR
            MENUITEM "Address Error",               IDM_DIS_ADDRERR
            MENUITEM "Invalid Instruction",         IDM_DIS_INST
            MENUITEM "Zero Divide",                 IDM_DIS_ZERODIV
