        MENUITEM "&Encendido",                  IDM_POWER
        MENUITEM SEPARATOR
        MENUITEM "&Salir\tAlt+F4",              IDM_EXIT
    END
    POPUP "Floppy Disco #&0"
    BEGIN
        MENUITEM "&Abrir...",                   IDM_D0OPEN
        MENUITEM "&Expulsar",                   IDM_D0EJECT
