        MENUITEM "&Iconic",                     IDM_ICONIC
        MENUITEM "&Arrange Icon",               IDM_ARRANGEICON
        MENUITEM "&Hide",                       IDM_HIDE
        MENUITEM "&Restore",                    IDM_RESTORE
    END
