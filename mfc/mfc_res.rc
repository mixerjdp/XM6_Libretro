IDR_ES_MENU MENU
BEGIN
    POPUP "&Archivo"
    BEGIN
        MENUITEM "&Abrir...",                   IDM_OPEN
        MENUITEM "Carga r∥pida\tF7",           ID_FILE_CARGAR40006
        MENUITEM "&Guardar",                    IDM_SAVE
        MENUITEM "Guardado r∥pido\tF5",        IDM_SAVEAS
        MENUITEM SEPARATOR
