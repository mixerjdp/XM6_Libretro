            MENUITEM "(A7+0E) : $000000",           IDM_STACK_7
            MENUITEM "(A7+10) : $000000",           IDM_STACK_8
            MENUITEM "(A7+12) : $000000",           IDM_STACK_9
            MENUITEM "(A7+14) : $000000",           IDM_STACK_A
            MENUITEM "(A7+16) : $000000",           IDM_STACK_B
            MENUITEM "(A7+18) : $000000",           IDM_STACK_C
            MENUITEM "(A7+1A) : $000000",           IDM_STACK_D
            MENUITEM "(A7+1C) : $000000",           IDM_STACK_E
            MENUITEM "(A7+1E) : $000000",           IDM_STACK_F
        END
        POPUP "гГїпљљGгГїпљљгГїпљљгГїпљљAгГїпљљгГїпљљгГїпљљпЊЪжМЗгГїпљљгГїпљљ(&D)"
        BEGIN
