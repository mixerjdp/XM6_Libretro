        POPUP "&Direct Select"
        BEGIN
            MENUITEM "$000000 : MPU Vector",        IDM_AREA_MPU
            MENUITEM "$000400 : IOCS Vector",       IDM_AREA_IOCS
            MENUITEM "$001800 : DOS Vector",        IDM_AREA_DOS
